# Database
DATABASE_URL=postgresql://user:password@localhost:5432/clearfintech
DATABASE_REPLICA_URL=postgresql://user:password@localhost:5433/clearfintech

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=replace-with-256-bit-secret
JWT_REFRESH_SECRET=replace-with-separate-256-bit-secret
SESSION_SECRET=replace-with-session-secret

# Encryption (AES-256-GCM for PII at rest)
ENCRYPTION_KEY=replace-with-64-char-hex-key
ENCRYPTION_IV_LENGTH=16

# Payment Processing
PAYMENT_GATEWAY_API_KEY=replace-with-gateway-key
PAYMENT_GATEWAY_SECRET=replace-with-gateway-secret
PAYMENT_GATEWAY_MERCHANT_ID=replace-with-merchant-id
TOKENIZATION_SERVICE_URL=https://tokenizer.example.com/v1

# Compliance / Reporting
FINCEN_API_KEY=replace-with-fincen-key
FINCEN_FILING_ENDPOINT=https://api.fincen.gov/v1/sar
AML_THRESHOLD_SINGLE_TRANSACTION=10000
AML_THRESHOLD_CUMULATIVE_DAILY=25000

# Monitoring
SENTRY_DSN=replace-with-sentry-dsn
LOG_LEVEL=info

# Environment
NODE_ENV=development
PORT=3001
